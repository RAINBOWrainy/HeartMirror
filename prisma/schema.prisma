// Local mode schema - SQLite for fully local self-hosted

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  // Encrypted content containing the array of messages
  // Format when decrypted: JSON array of { role, content, timestamp }
  encryptedContent Bytes
  // Initialization vector for AES-256-GCM
  iv Bytes
  // Authentication tag for authenticated encryption
  authTag Bytes
  // Salt used for PBKDF2 key derivation during encryption
  salt Bytes

  // === Encrypted Preview (Fast List Loading) ===
  // Small encrypted preview for sidebar - avoids decrypting entire conversation
  previewCiphertext Bytes?
  previewIv         Bytes?
  previewAuthTag    Bytes?
  previewSalt       Bytes?
}

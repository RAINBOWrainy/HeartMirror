{
  "interventions": {
    "cbt": {
      "name": "认知行为疗法",
      "type": "心理治疗",
      "description": "通过识别和改变消极思维模式来改善情绪",
      "duration": "12-20次",
      "suitable_for": ["depression", "anxiety", "stress"],
      "evidence_level": "high",
      "techniques": [
        {
          "name": "认知重构",
          "description": "识别消极自动思维，挑战不合理信念",
          "steps": [
            "识别触发事件",
            "记录自动思维",
            "评估证据支持/反对",
            "形成替代性思维"
          ]
        },
        {
          "name": "行为激活",
          "description": "通过增加积极活动改善情绪",
          "steps": [
            "列出愉悦活动",
            "制定活动计划",
            "逐步实施",
            "记录感受变化"
          ]
        }
      ]
    },
    "mindfulness": {
      "name": "正念冥想",
      "type": "自助练习",
      "description": "培养对当下经验的觉察和接纳",
      "duration": "每日10-30分钟",
      "suitable_for": ["anxiety", "stress", "chronic_pain"],
      "evidence_level": "high",
      "techniques": [
        {
          "name": "呼吸冥想",
          "description": "专注于呼吸的冥想练习",
          "duration_minutes": 10,
          "steps": [
            "找到安静的地方坐下",
            "闭上眼睛，关注呼吸",
            "当注意力分散时，温和地回到呼吸",
            "逐渐扩展觉察范围"
          ]
        },
        {
          "name": "身体扫描",
          "description": "逐步关注身体各部位的感觉",
          "duration_minutes": 20,
          "steps": [
            "躺下或舒适坐着",
            "从头顶开始，逐步向下",
            "观察每个部位的感觉",
            "不做判断，只是观察"
          ]
        }
      ]
    },
    "breathing": {
      "name": "呼吸训练",
      "type": "自助练习",
      "description": "通过控制呼吸来调节自主神经系统",
      "duration": "5-15分钟",
      "suitable_for": ["anxiety", "panic", "stress"],
      "evidence_level": "medium",
      "techniques": [
        {
          "name": "4-7-8呼吸法",
          "description": "快速缓解焦虑的呼吸技巧",
          "steps": [
            "用鼻子吸气，数4秒",
            "屏住呼吸，数7秒",
            "用嘴呼气，数8秒",
            "重复3-4次"
          ]
        },
        {
          "name": "腹式呼吸",
          "description": "深度放松的呼吸方式",
          "steps": [
            "一手放胸口，一手放腹部",
            "用鼻子慢吸气，腹部隆起",
            "用嘴慢呼气，腹部下沉",
            "练习5-10分钟"
          ]
        }
      ]
    },
    "exercise": {
      "name": "运动疗法",
      "type": "生活方式",
      "description": "通过身体活动改善心理健康",
      "duration": "每周150分钟",
      "suitable_for": ["depression", "anxiety"],
      "evidence_level": "high",
      "techniques": [
        {
          "name": "有氧运动",
          "description": "快走、跑步、游泳等",
          "steps": [
            "选择喜欢的运动",
            "从低强度开始",
            "逐渐增加时间",
            "保持规律性"
          ]
        }
      ]
    },
    "social": {
      "name": "社交活动",
      "type": "生活方式",
      "description": "建立和维护社会支持网络",
      "suitable_for": ["depression", "loneliness"],
      "evidence_level": "medium",
      "techniques": [
        {
          "name": "社交计划",
          "description": "安排与朋友家人的互动",
          "steps": [
            "列出重要的人",
            "主动联系他们",
            "安排具体活动",
            "保持定期联系"
          ]
        }
      ]
    }
  }
}
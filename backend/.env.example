# HeartMirror Backend Environment Variables

# Application
APP_NAME=HeartMirror
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database - PostgreSQL (本地开发)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/heartmirror
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/heartmirror

# Database - Supabase (生产环境)
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j AuraDB (生产环境)
# NEO4J_URI=neo4j+s://[INSTANCE-ID].databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=[YOUR-PASSWORD]

# OpenRouter LLM API
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=arcee-ai/trinity-large-preview:free

# LangChain
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langchain-api-key

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Crisis Support - 心理援助热线
CRISIS_HOTLINE=400-161-9995
CRISIS_RESOURCES={"beijing":"010-82951332","shanghai":"021-34289888"}
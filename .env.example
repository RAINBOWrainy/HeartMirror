# HeartMirror Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# DEPLOYMENT MODE
# ============================================
# Leave empty/unset for local mode (SQLite, browser-only)
# Set to "cloud" for cloud mode (PostgreSQL, authentication)

# DEPLOY_MODE=cloud

# ============================================
# LOCAL MODE (default)
# ============================================
# No additional environment variables needed for local mode
# Data is stored in SQLite at prisma/dev.db
# All encryption happens client-side

# ============================================
# CLOUD MODE
# ============================================

# Database (PostgreSQL)
# For local development, use Docker: docker run -p 5432:5432 -e POSTGRES_USER=test -e POSTGRES_PASSWORD=test -e POSTGRES_DB=heartmirror postgres:16-alpine
DATABASE_URL="postgresql://test:test@localhost:5432/heartmirror"

# JWT Configuration (RS256 Asymmetric Keys)
# Generate with: openssl genrsa -out private.pem 2048
# Then: openssl rsa -in private.pem -pubout -out public.pem
# Paste the contents below (including the header/footer lines)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# Rate Limiting (Upstash Redis)
# Sign up at https://upstash.com and create a Redis database
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# Email (Resend)
# Sign up at https://resend.com and add your API key
RESEND_API_KEY="re_your_api_key_here"

# Application URL (for email links)
NEXT_PUBLIC_APP_URL="http://localhost:3003"

# ============================================
# GENERATING RSA KEY PAIR
# ============================================
# Run these commands in your terminal:

# Generate private key:
# openssl genrsa -out private.pem 2048

# Extract public key:
# openssl rsa -in private.pem -pubout -out public.pem

# Copy the key contents to the variables above.
# NEVER commit private.pem or .env.local to git!

# ============================================
# LOCAL DEVELOPMENT WITH CLOUD MODE
# ============================================
# 1. Start PostgreSQL:
#    docker run -d --name heartmirror-postgres -p 5432:5432 \
#      -e POSTGRES_USER=test \
#      -e POSTGRES_PASSWORD=test \
#      -e POSTGRES_DB=heartmirror \
#      postgres:16-alpine

# 2. Run migrations:
#    DEPLOY_MODE=cloud npx prisma migrate deploy

# 3. Start dev server:
#    DEPLOY_MODE=cloud npm run dev

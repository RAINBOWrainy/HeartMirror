  },
  "scripts": {
    "dev": "if [ -z \"$DEPLOY_MODE\" ]; then DEPLOY_MODE=local; fi && cp prisma/schema-$DEPLOY_MODE.prisma prisma/schema.prisma && next dev -p 3003",
    "build": "if [ -z \"$DEPLOY_MODE\" ]; then DEPLOY_MODE=local; fi && cp prisma/schema-$DEPLOY_MODE.prisma prisma/schema.prisma && npx prisma generate && next build",
    "start": "next start -p 3003",
    "lint": "next lint",
    "test": "npx vitest run"
  },

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HeartMirror",
  "version": "1.0.0",
  "identifier": "com.heartmirror.app",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "HeartMirror - 心镜",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://heartmirror-backend-free.onrender.com wss://heartmirror-backend-free.onrender.com http://localhost:8000 ws://localhost:8000; img-src 'self' data: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Healthcare",
    "shortDescription": "AI心理健康自助管理系统",
    "longDescription": "HeartMirror是一款闭环循证AI心理健康自助管理系统，面向18-28岁学生与年轻职场人群，提供情绪识别、风险评估、干预推荐等功能。",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}